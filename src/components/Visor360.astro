---
// Visor360.astro
const imagenSala = "/Panorama(4)p.webp"; 
---

<div id="panorama-wrapper" style="width: 100%; height: 100vh; position: relative; background-color: #2c2c2c;">
  <div id="panorama" style="width: 100%; height: 100%;"></div>
</div>

<style is:global>
  .flecha-animada {
    width: 50px; height: 50px;
    background-color: rgba(0,0,0,0.2);
    border-radius: 50%;
    border: 3px solid white;
    position: relative;
    cursor: pointer;
    pointer-events: auto;
  }
  .pnlm-load-box { display: none !important; }
  .flecha-animada::after {
    content: "∧"; color: white;
    font-family: Arial, sans-serif; font-size: 32px; font-weight: bold;
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%, -55%);
  }
  .flecha-animada::before {
    content: "";
    position: absolute; top: -12px; left: -12px; right: -12px; bottom: -12px;
    border: 3px solid white; border-radius: 50%;
    animation: latido 1.5s infinite ease-out;
  }
  @keyframes latido {
    0%   { transform: scale(0.8); opacity: 1; }
    100% { transform: scale(1.2); opacity: 0; }
  }
  .pnlm-tooltip { display: none !important; }
</style>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/pannellum@2.5.6/build/pannellum.css"/>
<script is:inline src="https://cdn.jsdelivr.net/npm/pannellum@2.5.6/build/pannellum.js"></script>

<script define:vars={{ imagenSala}}>
  let visor = null;

  const escenas = [
    { id: 'sala 1',  label: 'sala1',  icono: '🛋️' },
  ];

  // Inyectar estilos de animación del chevron (solo lo que no se puede hacer inline)
  const inyectarEstilos = () => {
    const tag = document.createElement('style');
    tag.textContent = `
      #menu-360-trigger.open #menu-360-chevron { transform: rotate(180deg); }
      #menu-360-item-hover:hover { background: rgba(255,255,255,0.12) !important; color: #fff !important; }
    `;
    document.head.appendChild(tag);
  };

  const crearMenu = () => {
    inyectarEstilos();
    const wrapper = document.getElementById('panorama-wrapper');

    // Contenedor
    const menuWrapper = document.createElement('div');
    menuWrapper.id = 'menu-360-wrapper';
    Object.assign(menuWrapper.style, {
      position: 'absolute',
      top: '16px',
      left: '50%',
      transform: 'translateX(-50%)',
      zIndex: '200',
      width: 'min(55vw, 220px)',
      fontFamily: 'system-ui, -apple-system, sans-serif',
    });

    // Trigger button
    const trigger = document.createElement('button');
    trigger.id = 'menu-360-trigger';
    Object.assign(trigger.style, {
      all: 'unset',             // <-- resetea TODO estilo heredado
      boxSizing: 'border-box',
      width: '100%',
      background: 'rgba(0,0,0,0.62)',
      border: '1px solid rgba(255,255,255,0.28)',
      borderRadius: '30px',
      padding: '8px 14px',
      color: '#fff',
      fontSize: '13px',
      fontFamily: 'system-ui, -apple-system, sans-serif',
      cursor: 'pointer',
      display: 'flex',
      alignItems: 'center',
      justifyContent: 'space-between',
      gap: '8px',
      WebkitTapHighlightColor: 'transparent',
    });

    const labelSpan = document.createElement('span');
    labelSpan.id = 'menu-360-label';
    labelSpan.textContent = 'sala1';
    Object.assign(labelSpan.style, { flex: '1', whiteSpace: 'nowrap', overflow: 'hidden', textOverflow: 'ellipsis' });

    const chevron = document.createElement('span');
    chevron.id = 'menu-360-chevron';
    chevron.textContent = '▼';
    Object.assign(chevron.style, {
      fontSize: '10px',
      opacity: '0.65',
      flexShrink: '0',
      transition: 'transform 0.25s',
      display: 'inline-block',
    });

    trigger.appendChild(labelSpan);
    trigger.appendChild(chevron);

    // Dropdown
    const dropdown = document.createElement('div');
    dropdown.id = 'menu-360-dropdown';
    Object.assign(dropdown.style, {
      display: 'none',
      flexDirection: 'column',
      marginTop: '6px',
      background: 'rgba(18,18,18,0.95)',
      border: '1px solid rgba(255,255,255,0.14)',
      borderRadius: '16px',
      overflow: 'hidden',
    });

    escenas.forEach(({ id, label, icono }, idx) => {
      const btn = document.createElement('button');
      btn.dataset.escena = id;
      btn.innerHTML = `<span style="font-size:14px">${icono}</span><span>${label}</span>`;
      Object.assign(btn.style, {
        all: 'unset',           // <-- resetea TODO estilo heredado
        boxSizing: 'border-box',
        padding: '11px 16px',
        color: 'rgba(255,255,255,0.82)',
        fontSize: '13px',
        fontFamily: 'system-ui, -apple-system, sans-serif',
        cursor: 'pointer',
        display: 'flex',
        alignItems: 'center',
        gap: '10px',
        width: '100%',
        WebkitTapHighlightColor: 'transparent',
        borderBottom: idx < escenas.length - 1 ? '0.5px solid rgba(255,255,255,0.08)' : 'none',
        transition: 'background 0.15s',
      });

      btn.addEventListener('mouseenter', () => {
        if (!btn.dataset.activo) {
          btn.style.background = 'rgba(255,255,255,0.1)';
          btn.style.color = '#fff';
        }
      });
      btn.addEventListener('mouseleave', () => {
        if (!btn.dataset.activo) {
          btn.style.background = 'transparent';
          btn.style.color = 'rgba(255,255,255,0.82)';
        }
      });

      btn.addEventListener('click', () => {
        if (visor) visor.loadScene(id);
        actualizarMenu(id);
        cerrarMenu();
      });

      dropdown.appendChild(btn);
    });

    menuWrapper.appendChild(trigger);
    menuWrapper.appendChild(dropdown);
    wrapper.appendChild(menuWrapper);

    // Toggle
    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      const abierto = dropdown.style.display === 'flex';
      if (abierto) {
        cerrarMenu();
      } else {
        dropdown.style.display = 'flex';
        trigger.classList.add('open');
        chevron.style.transform = 'rotate(180deg)';
      }
    });

    // Cerrar al clic fuera
    document.addEventListener('click', () => cerrarMenu());
    menuWrapper.addEventListener('click', (e) => e.stopPropagation());

    // Marcar cocina como activa por defecto
    actualizarMenu('sala 1');
    crearLoader(); // <-- agregar aquí
  };

  const cerrarMenu = () => {
    const dropdown = document.getElementById('menu-360-dropdown');
    const trigger  = document.getElementById('menu-360-trigger');
    const chevron  = document.getElementById('menu-360-chevron');
    if (!dropdown) return;
    dropdown.style.display = 'none';
    trigger && trigger.classList.remove('open');
    chevron && (chevron.style.transform = 'rotate(0deg)');
  };

  const actualizarMenu = (escenaId) => {
    const escena = escenas.find(e => e.id === escenaId);
    if (!escena) return;

    const label = document.getElementById('menu-360-label');
    if (label) label.textContent = `${escena.icono} ${escena.label}`;

    document.querySelectorAll('#menu-360-dropdown button').forEach(btn => {
      const esActivo = btn.dataset.escena === escenaId;
      btn.dataset.activo = esActivo ? '1' : '';
      Object.assign(btn.style, esActivo
        ? { background: 'rgba(255,255,255,0.9)', color: '#1a1a1a', fontWeight: '600' }
        : { background: 'transparent', color: 'rgba(255,255,255,0.82)', fontWeight: '400' }
      );
    });
  };

  const crearLoader = () => {
  const loader = document.createElement('div');
  loader.id = 'loader-360';
  Object.assign(loader.style, {
    position: 'absolute',
    bottom: '24px',
    left: '50%',
    transform: 'translateX(-50%)',
    zIndex: '200',
    display: 'none',
    alignItems: 'center',
    gap: '8px',
    background: 'rgba(0,0,0,0.55)',
    border: '1px solid rgba(255,255,255,0.15)',
    borderRadius: '30px',
    padding: '7px 16px',
    color: 'rgba(255,255,255,0.85)',
    fontSize: '12px',
    fontFamily: 'system-ui, -apple-system, sans-serif',
    pointerEvents: 'none',
  });

  // Spinner SVG inline
  loader.innerHTML = `
    <svg width="14" height="14" viewBox="0 0 14 14" style="animation: giro360 0.8s linear infinite; flex-shrink:0;">
      <circle cx="7" cy="7" r="5.5" fill="none" stroke="rgba(255,255,255,0.25)" stroke-width="1.5"/>
      <path d="M7 1.5 A5.5 5.5 0 0 1 12.5 7" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
    <span>Cargando...</span>
  `;

  // Keyframe solo del spinner (mínimo inevitable)
  const style = document.createElement('style');
  style.textContent = `@keyframes giro360 { to { transform: rotate(360deg); } }`;
  document.head.appendChild(style);

  document.getElementById('panorama-wrapper').appendChild(loader);
};

const mostrarLoader = () => {
  const loader = document.getElementById('loader-360');
  if (loader) loader.style.display = 'flex';
};

const ocultarLoader = () => {
  const loader = document.getElementById('loader-360');
  if (loader) loader.style.display = 'none';
};

  const iniciarVisor = () => {
    if (document.getElementById('panorama') && typeof pannellum !== 'undefined') {
      crearMenu();

      visor = pannellum.viewer('panorama', {
        "default": {
          "firstScene": "sala 1",
          "sceneFadeDuration": 1000,
          "autoLoad": true,
          "showControls": true,
          "autoRotate": 0
        },
        "scenes": {
          "sala 1": {
            "type": "equirectangular",
            "panorama": imagenSala,
            "hotSpots": []
          }
        }
      });

      visor.on('scenechange', (escenaId) => {
        actualizarMenu(escenaId);
        mostrarLoader();
      });

      visor.on('load', () => {
        ocultarLoader();
      });

    } else {
      setTimeout(iniciarVisor, 50);
    }
  };

  iniciarVisor();
</script>